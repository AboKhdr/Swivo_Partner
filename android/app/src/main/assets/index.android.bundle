093e, \u0939\u092e \u091c\u0932\u094d\u0926 \u0938\u0902\u092a\u0930\u094d\u0915 \u0915\u0930\u0947\u0902\u0917\u0947",send:"\u0938\u0902\u0926\u0947\u0936 \u092d\u0947\u091c\u0947\u0902"},terms:{title:"\u0928\u093f\u092f\u092e \u090f\u0935\u0902 \u0936\u0930\u094d\u0924\u0947\u0902",lastUpdated:"\u0905\u0902\u0924\u093f\u092e \u0905\u092a\u0921\u0947\u091f: \u092e\u0908 2025 \u2014 \u0915\u0943\u092a\u092f\u093e \u0910\u092a \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0928\u0947 \u0938\u0947 \u092a\u0939\u0932\u0947 \u092f\u0947 \u0936\u0930\u094d\u0924\u0947\u0902 \u0927\u094d\u092f\u093e\u0928 \u0938\u0947 \u092a\u0922\u093c\u0947\u0902\u0964",sections:[{title:"\u0936\u0930\u094d\u0924\u094b\u0902 \u0915\u0940 \u0938\u094d\u0935\u0940\u0915\u0943\u0924\u093f",body:"\u0924\u092e\u093e\u092e \u0910\u092a \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0915\u0947 \u0906\u092a \u0907\u0928 \u0928\u093f\u092f\u092e\u094b\u0902 \u0914\u0930 \u0936\u0930\u094d\u0924\u094b\u0902 \u0938\u0947 \u092c\u0902\u0927\u0947 \u0939\u094b\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0938\u0939\u092e\u0924 \u0939\u0948\u0902\u0964 \u092f\u0926\u093f \u0906\u092a \u0915\u093f\u0938\u0940 \u092d\u0940 \u0936\u0930\u094d\u0924 \u0938\u0947 \u0905\u0938\u0939\u092e\u0924 \u0939\u0948\u0902, \u0924\u094b \u0915\u0943\u092a\u092f\u093e \u0924\u0941\u0930\u0902\u0924 \u0910\u092a \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u092c\u0902\u0926 \u0915\u0930\u0947\u0902\u0964"},{title:"\u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0940 \u0917\u0908 \u0938\u0947\u0935\u093e\u090f\u0902",body:"\u0924\u092e\u093e\u092e \u0910\u092a \u0915\u093e\u0930 \u0935\u0949\u0936 \u092e\u093e\u0932\u093f\u0915\u094b\u0902 \u0915\u094b \u0917\u094d\u0930\u093e\u0939\u0915\u094b\u0902 \u0938\u0947 \u091c\u094b\u0921\u093c\u0928\u0947 \u0935\u093e\u0932\u093e \u092a\u094d\u0932\u0947\u091f\u092b\u093c\u0949\u0930\u094d\u092e \u0939\u0948\u0964 \u0938\u0947\u0935\u093e\u0913\u0902 \u092e\u0947\u0902 \u0936\u093e\u092e\u093f\u0932 \u0939\u0948\u0902: \u0911\u0930\u094d\u0921\u0930 \u092a\u094d\u0930\u092c\u0902\u0927\u0928, \u092c\u093e\u0907\u0915\u0930 \u091f\u094d\u0930\u0948\u0915\u093f\u0902\u0917, \u0936\u093e\u0916\u093e \u0914\u0930 \u0938\u094d\u091f\u093e\u092b \u092a\u094d\u0930\u092c\u0902\u0927\u0928, \u0914\u0930 \u092d\u0941\u0917\u0924\u093e\u0928 \u0930\u093f\u0915\u0949\u0930\u094d\u0921\u0964"},{title:"\u0917\u094b\u092a\u0928\u0940\u092f\u0924\u093e \u0914\u0930 \u0921\u0947\u091f\u093e \u0938\u0941\u0930\u0915\u094d\u0937\u093e",body:"\u0939\u092e \u0938\u090a\u0926\u0940 \u0905\u0930\u092c \u0915\u0947 \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u0921\u0947\u091f\u093e \u0938\u0902\u0930\u0915\u094d\u0937\u0923 \u0928\u093f\u092f\u092e\u094b\u0902 \u0915\u0947 \u0905\u0928\u0941\u0938\u093e\u0930 \u0906\u092a\u0915\u0947 \u0921\u0947\u091f\u093e \u0915\u0940 \u0938\u0941\u0930\u0915\u094d\u0937\u093e \u0915\u0947 \u0932\u093f\u090f \u092a\u094d\u0930\u0924\u093f\u092c\u0926\u094d\u0927 \u0939\u0948\u0902\u0964 \u0906\u092a\u0915\u093e \u0921\u0947\u091f\u093e \u0906\u092a\u0915\u0940 \u0938\u0939\u092e\u0924\u093f \u0915\u0947 \u092c\u093f\u0928\u093e \u0915\u093f\u0938\u0940 \u0924\u0943\u0924\u0940\u092f \u092a\u0915\u094d\u0937 \u0915\u0947 \u0938\u093e\u0925 \u0938\u093e\u091d\u093e \u0928\u0939\u0940\u0902 \u0915\u093f\u092f\u093e \u091c\u093e\u090f\u0917\u093e\u0964"},{title:"\u092d\u0941\u0917\u0924\u093e\u0928 \u0914\u0930 \u091a\u093e\u0932\u093e\u0928",body:"\u0938\u092d\u0940 \u0930\u093e\u0936\u093f\u092f\u093e\u0902 \u0938\u090a\u0926\u0940 \u0930\u093f\u092f\u093e\u0932 \u092e\u0947\u0902 \u0939\u0948\u0902 \u0914\u0930 \u0935\u0948\u091f \u0938\u0939\u093f\u0924 \u0939\u0948\u0902\u0964 \u0915\u0902\u092a\u0928\u0940 \u0915\u092e \u0938\u0947 \u0915\u092e 30 \u0926\u093f\u0928 \u092a\u0939\u0932\u0947 \u0938\u0942\u091a\u0928\u093e \u0915\u0947 \u0938\u093e\u0925 \u0938\u0926\u0938\u094d\u092f\u0924\u093e \u092e\u0942\u0932\u094d\u092f \u092c\u0926\u0932 \u0938\u0915\u0924\u0940 \u0939\u0948\u0964 \u0938\u092e\u093e\u092a\u094d\u0924 \u0905\u0935\u0927\u093f \u0915\u0947 \u0936\u0941\u0932\u094d\u0915 \u0935\u093e\u092a\u0938 \u0928\u0939\u0940\u0902 \u0915\u093f\u090f \u091c\u093e\u090f\u0902\u0917\u0947\u0964"},{title:"\u0938\u0947\u0935\u093e \u092a\u094d\u0930\u0926\u093e\u0924\u093e \u0926\u093e\u092f\u093f\u0924\u094d\u0935",body:"\u0938\u0947\u0935\u093e \u092a\u094d\u0930\u0926\u093e\u0924\u093e \u0909\u091a\u094d\u091a \u0917\u0941\u0923\u0935\u0924\u094d\u0924\u093e \u0915\u0947 \u0938\u093e\u0925 \u0938\u0947\u0935\u093e\u090f\u0902 \u0926\u0947\u0928\u0947, \u0928\u093f\u0930\u094d\u0927\u093e\u0930\u093f\u0924 \u0915\u093e\u0930\u094d\u092f \u0938\u092e\u092f \u0915\u093e \u092a\u093e\u0932\u0928 \u0915\u0930\u0928\u0947, \u0914\u0930 \u0915\u093f\u0938\u0940 \u092d\u0940 \u0938\u092e\u0938\u094d\u092f\u093e \u0915\u0940 \u0924\u0941\u0930\u0902\u0924 \u0930\u093f\u092a\u094b\u0930\u094d\u091f \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u092a\u094d\u0930\u0924\u093f\u092c\u0926\u094d\u0927 \u0939\u0948\u0964"},{title:"\u0938\u0947\u0935\u093e \u0938\u092e\u093e\u092a\u094d\u0924\u093f",body:"\u0915\u094b\u0908 \u092d\u0940 \u092a\u0915\u094d\u0937 14 \u0926\u093f\u0928 \u0915\u0940 \u092a\u0942\u0930\u094d\u0935 \u0938\u0942\u091a\u0928\u093e \u0915\u0947 \u0938\u093e\u0925 \u0938\u092e\u091d\u094c\u0924\u093e \u0938\u092e\u093e\u092a\u094d\u0924 \u0915\u0930 \u0938\u0915\u0924\u093e \u0939\u0948\u0964 \u0907\u0928 \u0936\u0930\u094d\u0924\u094b\u0902 \u0915\u0947 \u0909\u0932\u094d\u0932\u0902\u0918\u0928 \u092a\u0930 \u0915\u0902\u092a\u0928\u0940 \u0924\u0941\u0930\u0902\u0924 \u0916\u093e\u0924\u093e \u0928\u093f\u0932\u0902\u092c\u093f\u0924 \u0915\u0930 \u0938\u0915\u0924\u0940 \u0939\u0948\u0964"},{title:"\u0932\u093e\u0917\u0942 \u0915\u093e\u0928\u0942\u0928",body:"\u092f\u0947 \u0928\u093f\u092f\u092e \u0914\u0930 \u0936\u0930\u094d\u0924\u0947\u0902 \u0938\u090a\u0926\u0940 \u0905\u0930\u092c \u0915\u0947 \u0915\u093e\u0928\u0942\u0928\u094b\u0902 \u0915\u0947 \u0905\u0902\u0924\u0930\u094d\u0917\u0924 \u0939\u0948\u0902\u0964 \u0907\u0928 \u0936\u0930\u094d\u0924\u094b\u0902 \u0938\u0947 \u0909\u0924\u094d\u092a\u0928\u094d\u0928 \u0915\u093f\u0938\u0940 \u092d\u0940 \u0935\u093f\u0935\u093e\u0926 \u092e\u0947\u0902 \u0938\u090a\u0926\u0940 \u0928\u094d\u092f\u093e\u092f\u093e\u0932\u092f\u094b\u0902 \u0915\u093e \u0905\u0927\u093f\u0915\u093e\u0930 \u0915\u094d\u0937\u0947\u0924\u094d\u0930 \u0939\u094b\u0917\u093e\u0964"}]},plans:{title:"\u092f\u094b\u091c\u0928\u093e\u090f\u0902 \u0914\u0930 \u092e\u0942\u0932\u094d\u092f",intro:"\u0905\u092a\u0928\u0940 \u0932\u0949\u0928\u094d\u0921\u094d\u0930\u0940 \u0915\u0947 \u0932\u093f\u090f \u0938\u0930\u094d\u0935\u094b\u0924\u094d\u0924\u092e \u092f\u094b\u091c\u0928\u093e \u091a\u0941\u0928\u0947\u0902 \u0914\u0930 \u0905\u0927\u093f\u0915 \u0938\u0941\u0935\u093f\u0927\u093e\u090f\u0902 \u092a\u093e\u090f\u0902\u0964",monthly:"\u092e\u093e\u0938\u093f\u0915",yearly:"\u0935\u093e\u0930\u094d\u0937\u093f\u0915",unlimited:"\u0906\u091c\u0940\u0935\u0928",popular:"\u0938\u092c\u0938\u0947 \u0932\u094b\u0915\u092a\u094d\u0930\u093f\u092f",currency:"SAR",perMonth:"/ \u092e\u093e\u0939",perYear:"/ \u0935\u0930\u094d\u0937",empty:"\u0905\u092d\u0940 \u0915\u094b\u0908 \u092f\u094b\u091c\u0928\u093e \u0909\u092a\u0932\u092c\u094d\u0927 \u0928\u0939\u0940\u0902",error:"\u092f\u094b\u091c\u0928\u093e\u090f\u0902 \u0932\u094b\u0921 \u0915\u0930\u0928\u0947 \u092e\u0947\u0902 \u0935\u093f\u092b\u0932",retry:"\u092a\u0941\u0928\u0903 \u092a\u094d\u0930\u092f\u093e\u0938 \u0915\u0930\u0947\u0902",free:"\u092e\u0941\u092b\u093c\u094d\u0924",feature:"\u0938\u0941\u0935\u093f\u0927\u093e",featuresCount:"{count} \u0938\u0941\u0935\u093f\u0927\u093e\u090f\u0902 \u0936\u093e\u092e\u093f\u0932"}},auth:{welcome:"\u0938\u094d\u0935\u093e\u0917\u0924 \u0939\u0948!",tagli