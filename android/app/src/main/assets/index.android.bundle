62a\u0637\u0628\u064a\u0642 \u062a\u0645\u0627\u0645 \u0628\u0627\u064a\u0643\u0631\u060c \u0641\u0625\u0646\u0643 \u062a\u0648\u0627\u0641\u0642 \u0639\u0644\u0649 \u0627\u0644\u0627\u0644\u062a\u0632\u0627\u0645 \u0628\u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637 \u0648\u0627\u0644\u0623\u062d\u0643\u0627\u0645. \u0625\u0630\u0627 \u0643\u0646\u062a \u0644\u0627 \u062a\u0648\u0627\u0641\u0642 \u0639\u0644\u0649 \u0623\u064a \u062c\u0632\u0621 \u0645\u0646 \u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637\u060c \u0641\u0644\u0627 \u064a\u062d\u0642 \u0644\u0643 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u062a\u0637\u0628\u064a\u0642."},{title:"\u0662. \u0637\u0628\u064a\u0639\u0629 \u0627\u0644\u062e\u062f\u0645\u0629",body:"\u062a\u0645\u0627\u0645 \u0628\u0627\u064a\u0643\u0631 \u0645\u0646\u0635\u0629 \u062a\u0631\u0628\u0637 \u0645\u0642\u062f\u0645\u064a \u062e\u062f\u0645\u0627\u062a \u063a\u0633\u064a\u0644 \u0627\u0644\u0633\u064a\u0627\u0631\u0627\u062a \u0628\u0627\u0644\u0639\u0645\u0644\u0627\u0621. \u0623\u0646\u062a \u0643\u0628\u0627\u064a\u0643\u0631 \u0645\u0633\u062a\u0642\u0644 \u0648\u0644\u064a\u0633 \u0645\u0648\u0638\u0641\u0627\u064b \u0644\u062f\u0649 \u062a\u0645\u0627\u0645\u060c \u0648\u062a\u062a\u062d\u0645\u0644 \u0645\u0633\u0624\u0648\u0644\u064a\u0629 \u0627\u0644\u062c\u0648\u062f\u0629 \u0648\u0633\u0644\u0627\u0645\u0629 \u062a\u0646\u0641\u064a\u0630 \u0627\u0644\u062e\u062f\u0645\u0629."},{title:"\u0663. \u0627\u0644\u0623\u0631\u0628\u0627\u062d \u0648\u0627\u0644\u0645\u062f\u0641\u0648\u0639\u0627\u062a",body:"\u062a\u064f\u062d\u062a\u0633\u0628 \u0623\u0631\u0628\u0627\u062d\u0643 \u0628\u0646\u0633\u0628\u0629 90% \u0645\u0646 \u0642\u064a\u0645\u0629 \u0643\u0644 \u0637\u0644\u0628 \u0645\u0646\u062c\u0632. \u062a\u064f\u0639\u0627\u0644\u062c \u0637\u0644\u0628\u0627\u062a \u0627\u0644\u0633\u062d\u0628 \u062e\u0644\u0627\u0644 \u064a\u0648\u0645\u064a \u0639\u0645\u0644. \u062a\u062d\u062a\u0641\u0638 \u062a\u0645\u0627\u0645 \u0628\u062d\u0642 \u062a\u0639\u062f\u064a\u0644 \u0646\u0633\u0628 \u0627\u0644\u0639\u0645\u0648\u0644\u0629 \u0645\u0639 \u0625\u0634\u0639\u0627\u0631 \u0645\u0633\u0628\u0642."},{title:"\u0664. \u0627\u0644\u0627\u0644\u062a\u0632\u0627\u0645\u0627\u062a \u0627\u0644\u0645\u0647\u0646\u064a\u0629",body:"\u064a\u0644\u062a\u0632\u0645 \u0627\u0644\u0628\u0627\u064a\u0643\u0631 \u0628\u0627\u0644\u062d\u0636\u0648\u0631 \u0641\u064a \u0627\u0644\u0648\u0642\u062a \u0627\u0644\u0645\u062d\u062f\u062f\u060c \u0648\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0645\u0639\u062f\u0627\u062a \u0627\u0644\u0645\u0646\u0627\u0633\u0628\u0629\u060c \u0648\u0627\u0644\u062d\u0641\u0627\u0638 \u0639\u0644\u0649 \u0645\u0645\u062a\u0644\u0643\u0627\u062a \u0627\u0644\u0639\u0645\u064a\u0644\u060c \u0648\u0627\u0644\u062a\u0635\u0631\u0641 \u0628\u0623\u0633\u0644\u0648\u0628 \u0645\u0647\u0646\u064a \u0641\u064a \u062c\u0645\u064a\u0639 \u0627\u0644\u0623\u0648\u0642\u0627\u062a."},{title:"\u0665. \u0625\u0644\u063a\u0627\u0621 \u0627\u0644\u0637\u0644\u0628\u0627\u062a",body:"\u064a\u064f\u0633\u0645\u062d \u0628\u0625\u0644\u063a\u0627\u0621 \u0627\u0644\u0637\u0644\u0628\u0627\u062a \u0641\u064a \u062d\u0627\u0644\u0627\u062a \u0627\u0633\u062a\u062b\u0646\u0627\u0626\u064a\u0629 \u0641\u0642\u0637. \u0627\u0644\u0625\u0644\u063a\u0627\u0621 \u0627\u0644\u0645\u062a\u0643\u0631\u0631 \u0642\u062f \u064a\u0624\u062b\u0631 \u0639\u0644\u0649 \u062a\u0642\u064a\u064a\u0645\u0643 \u0648\u064a\u064f\u0639\u0631\u0651\u0636 \u062d\u0633\u0627\u0628\u0643 \u0644\u0644\u062a\u0639\u0644\u064a\u0642."},{title:"\u0666. \u0627\u0644\u062e\u0635\u0648\u0635\u064a\u0629 \u0648\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a",body:"\u0646\u0644\u062a\u0632\u0645 \u0628\u062d\u0645\u0627\u064a\u0629 \u0628\u064a\u0627\u0646\u0627\u062a\u0643 \u0627\u0644\u0634\u062e\u0635\u064a\u0629 \u0648\u0641\u0642 \u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u062e\u0635\u0648\u0635\u064a\u0629 \u0627\u0644\u0645\u0639\u062a\u0645\u062f\u0629. \u0644\u0646 \u062a\u064f\u0634\u0627\u0631\u0643 \u0628\u064a\u0627\u0646\u0627\u062a\u0643 \u0645\u0639 \u0623\u0637\u0631\u0627\u0641 \u062b\u0627\u0644\u062b\u0629 \u0625\u0644\u0627 \u0628\u0645\u0648\u0627\u0641\u0642\u062a\u0643 \u0623\u0648 \u0628\u0645\u0648\u062c\u0628 \u0627\u0644\u0642\u0627\u0646\u0648\u0646."},{title:"\u0667. \u0625\u0646\u0647\u0627\u0621 \u0627\u0644\u062d\u0633\u0627\u0628",body:"\u064a\u062d\u0642 \u0644\u062a\u0645\u0627\u0645 \u062a\u0639\u0644\u064a\u0642 \u0623\u0648 \u0625\u0646\u0647\u0627\u0621 \u062d\u0633\u0627\u0628\u0643 \u0641\u064a \u062d\u0627\u0644 \u0627\u0646\u062a\u0647\u0627\u0643 \u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637. \u064a\u062d\u0642 \u0644\u0643 \u0625\u0646\u0647\u0627\u0621 \u062d\u0633\u0627\u0628\u0643 \u0641\u064a \u0623\u064a \u0648\u0642\u062a \u0639\u0628\u0631 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0645\u0639 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0641\u0646\u064a."}]}}},524,[]);
