30 \u0907\u0938\u0947 \u092a\u0942\u0930\u094d\u0935\u0935\u0924 \u0928\u0939\u0940\u0902 \u0915\u093f\u092f\u093e \u091c\u093e \u0938\u0915\u0924\u093e",deleteBtn:"\u092e\u0947\u0930\u093e \u0916\u093e\u0924\u093e \u0938\u094d\u0925\u093e\u092f\u0940 \u0930\u0942\u092a \u0938\u0947 \u0939\u091f\u093e\u090f\u0901",confirmTitle:"\u0905\u0902\u0924\u093f\u092e \u092a\u0941\u0937\u094d\u091f\u093f",confirmMessage:"\u0915\u094d\u092f\u093e \u0906\u092a \u092c\u093f\u0932\u094d\u0915\u0941\u0932 \u0928\u093f\u0936\u094d\u091a\u093f\u0924 \u0939\u0948\u0902? \u0906\u092a\u0915\u093e \u0916\u093e\u0924\u093e \u0914\u0930 \u0938\u093e\u0930\u093e \u0921\u0947\u091f\u093e 30 \u0926\u093f\u0928\u094b\u0902 \u0915\u0947 \u092d\u0940\u0924\u0930 \u0939\u091f\u093e \u0926\u093f\u092f\u093e \u091c\u093e\u090f\u0917\u093e\u0964",confirmBtn:"\u0939\u093e\u0901, \u0939\u091f\u093e\u090f\u0901",cancel:"\u0930\u0926\u094d\u0926 \u0915\u0930\u0947\u0902",errorTitle:"\u0916\u093e\u0924\u093e \u0939\u091f\u093e\u092f\u093e \u0928\u0939\u0940\u0902 \u091c\u093e \u0938\u0915\u093e",errorMessage:"\u0915\u0941\u091b \u0917\u0921\u093c\u092c\u0921\u093c \u0939\u0941\u0908\u0964 \u0915\u0943\u092a\u092f\u093e \u092c\u093e\u0926 \u092e\u0947\u0902 \u092a\u0941\u0928\u0903 \u092a\u094d\u0930\u092f\u093e\u0938 \u0915\u0930\u0947\u0902 \u092f\u093e \u0938\u0939\u093e\u092f\u0924\u093e \u0938\u0947 \u0938\u0902\u092a\u0930\u094d\u0915 \u0915\u0930\u0947\u0902\u0964",footnote:"\u0938\u090a\u0926\u0940 \u0905\u0930\u092c \u0915\u0947 \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u0921\u0947\u091f\u093e \u0938\u0902\u0930\u0915\u094d\u0937\u0923 \u0915\u093e\u0928\u0942\u0928 (PDPL) \u0915\u0947 \u0905\u0928\u0941\u0938\u093e\u0930, \u0906\u092a\u0915\u093e \u0921\u0947\u091f\u093e \u0905\u0928\u0941\u0930\u094b\u0927 \u0915\u0940 \u0924\u093e\u0930\u0940\u0916 \u0938\u0947 30 \u0926\u093f\u0928\u094b\u0902 \u0915\u0947 \u092d\u0940\u0924\u0930 \u0939\u091f\u093e \u0926\u093f\u092f\u093e \u091c\u093e\u090f\u0917\u093e\u0964 \u092a\u094d\u0930\u0936\u094d\u0928\u094b\u0902 \u0915\u0947 \u0932\u093f\u090f, \u0938\u0939\u093e\u092f\u0924\u093e \u0938\u0947 \u0938\u0902\u092a\u0930\u094d\u0915 \u0915\u0930\u0947\u0902\u0964"},personalInfo:{title:"\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u091c\u093e\u0928\u0915\u093e\u0930\u0940",myInfo:"\u092e\u0947\u0930\u0940 \u091c\u093e\u0928\u0915\u093e\u0930\u0940",name:"\u0928\u093e\u092e",firstName:"\u092a\u0939\u0932\u093e \u0928\u093e\u092e",lastName:"\u0909\u092a\u0928\u093e\u092e",phone:"\u092b\u093c\u094b\u0928 \u0928\u0902\u092c\u0930",email:"\u0908\u092e\u0947\u0932",dob:"\u091c\u0928\u094d\u092e \u0924\u093f\u0925\u093f",workArea:"\u0915\u093e\u0930\u094d\u092f \u0915\u094d\u0937\u0947\u0924\u094d\u0930",edit:"\u0938\u0902\u092a\u093e\u0926\u093f\u0924 \u0915\u0930\u0947\u0902",save:"\u092c\u0926\u0932\u093e\u0935 \u0938\u0939\u0947\u091c\u0947\u0902",changePhoto:"\u092b\u093c\u094b\u091f\u094b \u092c\u0926\u0932\u0947\u0902",takePhoto:"\u092b\u093c\u094b\u091f\u094b \u0932\u0947\u0902",chooseGallery:"\u0917\u0948\u0932\u0930\u0940 \u0938\u0947 \u091a\u0941\u0928\u0947\u0902",tapToChange:"\u092b\u093c\u094b\u091f\u094b \u092c\u0926\u0932\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u091f\u0948\u092a \u0915\u0930\u0947\u0902",uploadFailed:"\u092b\u093c\u094b\u091f\u094b \u0905\u092a\u0932\u094b\u0921 \u0935\u093f\u092b\u0932, \u092a\u0941\u0928\u0903 \u092a\u094d\u0930\u092f\u093e\u0938 \u0915\u0930\u0947\u0902",notSet:"\u0928\u093f\u0930\u094d\u0927\u093e\u0930\u093f\u0924 \u0928\u0939\u0940\u0902",branch:"\u0936\u093e\u0916\u093e"},wallet:{title:"\u092e\u0947\u0930\u093e \u0935\u0949\u0932\u0947\u091f",balance:"\u0935\u0930\u094d\u0924\u092e\u093e\u0928 \u0936\u0947\u0937:",today:"\u0906\u091c",noTransactions:"\u0905\u092d\u0940 \u0924\u0915 \u0915\u094b\u0908 \u0932\u0947\u0928\u0926\u0947\u0928 \u0928\u0939\u0940\u0902"},transactions:{title:"\u0932\u0947\u0928\u0926\u0947\u0928 \u0907\u092