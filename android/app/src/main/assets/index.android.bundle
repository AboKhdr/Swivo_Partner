d",mapLoading:"Loading map...",mapError:"Failed to load map",startOrder:"Start Order"},reviews:{title:"Reviews",rating:"Rating",all:"All",empty:"No reviews match this filter"},profile:{title:"Account",personalSettings:"Personal Settings",rating:"Rating",personalInfo:"Personal Information",personalInfoSub:"Basic info, work area",wallet:"My Wallet",options:"Options",appearance:"Appearance",darkMode:"Dark Mode",lightMode:"Light Mode",language:"Language",languageSub:"English",support:"Support",supportSub:"Submit a report",terms:"Terms & Conditions",termsSub:"Privacy Policy",logout:"Log Out",logoutSub:"Account",deleteAccount:"Delete Account",deleteAccountSub:"Permanently delete your account and data"},deleteAccount:{title:"Delete Account",warningTitle:"Warning: This action cannot be undone",warningBody:"Deleting your account will permanently remove all of your data from our servers. This cannot be reversed.",consequencesTitle:"What will be deleted?",bullet1:"Your personal info, phone number, and email",bullet2:"Your order history and past activity",bullet3:"Your wallet balance (if any) \u2014 please withdraw it first",bullet4:"Your reviews and feedback",reasonTitle:"Reason for deletion (optional)",reasonPlaceholder:"Help us improve \u2014 why are you deleting your account?",confirmCheckbox:"I understand this is permanent and cannot be undone",deleteBtn:"Delete My Account Permanently",confirmTitle:"Final Confirmation",confirmMessage:"Are you absolutely sure? Your account and all data will be deleted within 30 days.",confirmBtn:"Yes, delete",cancel:"Cancel",errorTitle:"Couldn't delete account",errorMessage:"Something went wrong. Please try again later or contact support.",footnote:"In compliance with Saudi Arabia's Personal Data Protection Law (PDPL), your data will be erased within 30 days of this request. For questions, contact support."},personalInfo:{title:"Personal Information",myInfo:"My Info",name:"Name",firstName:"First Name",lastName:"Last Name",phone:"Phone Numbe