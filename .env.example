# NativeTamam — Environment Variables Example
# Copy to .env and fill in real values. .env is gitignored.
#
# NOTE: Currently src/config.js still hardcodes values. To wire these up,
# install `react-native-config` and switch src/config.js to read Config.X.
# See tickets/build/BUILD-02 + BUILD-05 for migration plan.

# ── API ──────────────────────────────────────────────────────────────────────
PROD_BASE_URL=https://api.example.com/api
DEV_BASE_URL=http://192.168.1.5:3000/api

# ── Google Maps ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Restrict by: Android package name (com.partnerappnew) + SHA-1 fingerprint
GOOGLE_MAPS_API_KEY=AIza_replace_with_your_key

# ── Cloudinary ───────────────────────────────────────────────────────────────
# Used for image uploads (profile photos, order proof)
# Get from: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# ── Android Release Signing (CI only) ────────────────────────────────────────
# DO NOT commit. Used by GitHub Actions / CI pipeline.
# RELEASE_STORE_FILE=release.keystore
# RELEASE_STORE_PASSWORD=
# RELEASE_KEY_ALIAS=
# RELEASE_KEY_PASSWORD=
